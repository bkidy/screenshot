# 截图服务环境变量配置示例（轻量化版本）
# 复制此文件为 .env 并修改相应的值

# ===========================================
# 基础配置
# ===========================================

# 运行环境
NODE_ENV=production

# 服务端口
PORT=3002

# ===========================================
# 安全配置（可选）
# ===========================================

# API密钥（设置为 'disabled' 可关闭认证）
# 内网环境可以设置为 disabled 以简化配置
API_KEY=disabled

# CORS允许的源（设置为 '*' 允许所有源）
# 内网环境可以设置为 * 以简化配置
CORS_ORIGINS=*

# ===========================================
# 日志配置
# ===========================================

# 日志级别: error, warn, info, debug
LOG_LEVEL=info

# ===========================================
# 可选的高级配置
# ===========================================

# 如果需要启用认证，取消注释并设置强密码
# API_KEY=your-secret-api-key-here

# 如果需要限制CORS源，取消注释并设置具体域名
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# 如果需要调试，可以设置为 debug
# LOG_LEVEL=debug 